generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BusinessCase {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("draft") // draft, active, completed, archived
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  items       Item[]
}

model Item {
  id            String       @id @default(uuid())
  title         String
  description   String?
  category      String       // revenue, cost, resource, risk, opportunity
  estimatedValue Float?
  actualValue   Float?
  probability   Float?       // 0-1 para riesgos/oportunidades
  status        String       @default("pending") // pending, in-progress, completed, blocked
  priority      String       @default("medium") // low, medium, high, critical
  dueDate       DateTime?
  completedAt   DateTime?
  notes         String?
  businessCase  BusinessCase @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  businessCaseId String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model ChatSession {
  id        String    @id @default(uuid())
  messages  String    // JSON array de mensajes
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
